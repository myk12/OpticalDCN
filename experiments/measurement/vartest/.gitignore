# ----------------------------------------------------------------------
# P4 Compiler & Build Artifacts
# ----------------------------------------------------------------------
# Ignore the build directory where p4c outputs binaries (tofino.bin, context.json, etc.)
p4/build/

# ----------------------------------------------------------------------
# Intel/Barefoot SDE Runtime Logs & Artifacts
# ----------------------------------------------------------------------
# Ignore driver logs and their rotated backups (log.0, log.1, etc.)
bf_drivers.log*

# Ignore runtime logging configuration generated by the SDE
zlog-cfg-cur

# ----------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------
# Ignore compiled bytecode
__pycache__/
*.py[cod]
*$py.class

# ----------------------------------------------------------------------
# Local Configuration
# ----------------------------------------------------------------------
# Ignore local environment variables script (often contains local paths)
# Keep scripts/env.sh if that is the template, but ignore the root one if it's local.
env.sh

# ----------------------------------------------------------------------
# OS & Editor Files (Optional but recommended)
# ----------------------------------------------------------------------
.DS_Store
.vscode/
.idea/
*.swp

results
out
*.png
